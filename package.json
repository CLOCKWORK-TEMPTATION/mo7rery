{
  "name": "screenplay-editor",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.28.0",
  "type": "module",
  "description": "محرر سيناريو عربي مبني على Tiptap v3",
  "scripts": {
    "dev:app": "vite",
    "dev": "concurrently -k -n app,backend -c cyan,green \"pnpm run dev:app\" \"pnpm run file-import:server\"",
    "dev:full": "pnpm run dev",
    "build": "tsc && node --disable-warning=ExperimentalWarning node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "test": "vitest run --coverage --exclude tests/e2e/**",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run --config vitest.pipeline.config.ts",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:harness": "vitest run tests/harness",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "agent:setup": "tsx scripts/clean-workspace.ts",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test",
    "file-import:server": "node server/file-import-server.mjs",
    "build-antiword:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-antiword-windows.ps1",
    "build-antiword:linux": "powershell -ExecutionPolicy Bypass -File scripts/build-antiword-linux.ps1",
    "build-antiword": "powershell -ExecutionPolicy Bypass -File scripts/build-antiword.ps1",
    "smoke:extract": "powershell -ExecutionPolicy Bypass -File scripts/smoke-extract.ps1",
    "test:integration:watch": "vitest --config vitest.pipeline.config.ts",
    "test:e2e:ui": "playwright test --ui --config playwright.config.ts",
    "test:all": "pnpm run test:integration && pnpm run test:e2e",
    "test:coverage": "vitest run --config vitest.pipeline.config.ts --coverage",
    "pretest:all": "node -e \"require('fs').mkdirSync('test-results',{recursive:true})\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@mistralai/mistralai": "^1.14.0",
    "@tiptap-pro/extension-pages": "1.0.0-alpha.17-rc.9",
    "@tiptap/core": "^3.0.0",
    "@tiptap/extension-bold": "^3.0.0",
    "@tiptap/extension-bubble-menu": "^3.20.0",
    "@tiptap/extension-document": "^3.0.0",
    "@tiptap/extension-italic": "^3.0.0",
    "@tiptap/extension-table": "^3.20.0",
    "@tiptap/extension-text": "^3.0.0",
    "@tiptap/extension-text-align": "^3.20.0",
    "@tiptap/extension-underline": "^3.0.0",
    "@tiptap/pm": "^3.0.0",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "docx": "^9.5.3",
    "dotenv": "^17.3.1",
    "iconv-lite": "^0.7.2",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.474.0",
    "mammoth": "^1.11.0",
    "motion": "^12.34.2",
    "pdfjs-dist": "^5.4.624",
    "pino": "^9.14.0",
    "puppeteer": "^24.37.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "winax": "^3.6.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.56.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "knip": "^5.85.0",
    "postcss": "^8.5.6",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "supertest": "^7.1.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "winax"
    ]
  }
}
