ANTHROPIC_API_KEY=sk-ant-__REPLACE_ME__
MISTRAL_API_KEY=__REPLACE_ME__

# Local backend
FILE_IMPORT_HOST=127.0.0.1
FILE_IMPORT_PORT=8787

# Frontend endpoints
VITE_FILE_IMPORT_BACKEND_URL=http://127.0.0.1:8787/api/file-extract
VITE_AGENT_REVIEW_BACKEND_URL=http://127.0.0.1:8787/api/agent/review
VITE_AGENT_REVIEW_FAIL_OPEN=true

# Antiword runtime
ANTIWORD_PATH=C:/antiword/antiword.exe
ANTIWORDHOME=C:/antiword
HOME=C:/antiword

PDF_EXTRACTOR_MODE=mistral-script-strict
MISTRAL_PAGEWISE_CORRECTION_ENABLED=true
OPENAI_API_KEY=__REPLACE_ME__

# Moonshot / Kimi Vision Judge
MOONSHOT_API_KEY=__REPLACE_ME__

# PDF OCR Vision Models
PDF_VISION_COMPARE_MODEL=mistral-large-latest
PDF_VISION_JUDGE_MODEL=moonshot-v1-128k
