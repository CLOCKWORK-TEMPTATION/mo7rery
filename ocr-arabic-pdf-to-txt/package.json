{
  "name": "ocr-arabic-pdf-to-txt",
  "version": "1.0.0",
  "type": "module",
  "description": "وكيل OCR للملفات العربية — مبني على Vercel AI SDK v6 مع دعم MCP",
  "scripts": {
    "start": "tsx src/agent.ts",
    "start:batch": "tsx src/batch.ts",
    "dev": "tsx watch src/agent.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "build:mcp": "cd mcp-server && npm run build"
  },
  "dependencies": {
    "ai": "^6.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/mcp": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@mistralai/mistralai": "^1.5.0",
    "sharp": "^0.33.0",
    "zod": "^3.24.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0"
  }
}
