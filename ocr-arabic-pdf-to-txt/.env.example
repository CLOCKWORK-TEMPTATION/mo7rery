# ─── مفاتيح API المطلوبة ──────────────────────────────
# مفتاح Mistral — مطلوب لمحرك OCR الأساسي
MISTRAL_API_KEY=your_mistral_api_key_here

# مفتاح OpenAI — مطلوب لتشغيل الوكيل (GPT-4o / GPT-5)
OPENAI_API_KEY=your_openai_api_key_here

# ─── إعدادات اختيارية ─────────────────────────────────
# مسار خادم MCP الخاص بـ OCR (الافتراضي: ../index.ts من المشروع الأصلي)
# MCP_SERVER_PATH=../index.ts

# نموذج الوكيل (الافتراضي: gpt-4o)
# AGENT_MODEL=gpt-4o

# الحد الأقصى لخطوات الوكيل (الافتراضي: 10)
# AGENT_MAX_STEPS=10
