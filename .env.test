NODE_ENV=test
TEST_LOG_LEVEL=info
TEST_LOG_FILE=./test-results/test-run.log
MISTRAL_API_KEY=__REPLACE_IF_TESTING_OCR__
VITE_APP_PORT=5174
TEST_FIXTURES_DIR=./tests/fixtures
TEST_TIMEOUT_MS=30000
VITE_AGENT_REVIEW_FAIL_OPEN=true

# E2E audit execution
E2E_TARGET_URL=http://127.0.0.1:5174
APP_BASE_URL=http://127.0.0.1:5174
E2E_AUDIT_REPORT_DIR=./test-results
E2E_AUDIT_SCREENSHOT_DIR=./test-results/e2e-audit-screenshots
E2E_AUDIT_TIMEOUT_MS=180000
E2E_AUDIT_STRICT_MODE=false
E2E_AUDIT_ALLOWED_FAILED=0
E2E_AUDIT_ALLOWED_PARTIAL=9999
E2E_AUDIT_MIN_PASS_RATE=0
